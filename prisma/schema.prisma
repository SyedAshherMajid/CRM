generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  lotsCreated      PurchaseLot[]
  lotPayments      LotPayment[]
  phonesAdded      Phone[]
  salesMade        Sale[]
  salePayments     SalePayment[]
  supplierPayments SupplierPayment[]
  expenses         Expense[]

  @@map("users")
}

model Supplier {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  lots     PurchaseLot[]
  payments SupplierPayment[]

  @@map("suppliers")
}

model PurchaseLot {
  id          String   @id @default(uuid())
  name        String
  supplierId  String?  @map("supplier_id")
  totalAmount Decimal  @map("total_amount") @db.Decimal(12, 2)
  amountPaid  Decimal  @default(0) @map("amount_paid") @db.Decimal(12, 2)
  notes       String?
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  creator  User        @relation(fields: [createdBy], references: [id])
  supplier Supplier?   @relation(fields: [supplierId], references: [id])
  phones   Phone[]
  payments LotPayment[]

  @@index([supplierId])   // supplier detail page: filter lots by supplier
  @@index([createdAt])    // lots list: order by date
  @@map("purchase_lots")
}

model LotPayment {
  id         String   @id @default(uuid())
  lotId      String   @map("lot_id")
  amount     Decimal  @db.Decimal(12, 2)
  paidAt     DateTime @default(now()) @map("paid_at")
  notes      String?
  recordedBy String   @map("recorded_by")

  lot      PurchaseLot @relation(fields: [lotId], references: [id], onDelete: Cascade)
  recorder User        @relation(fields: [recordedBy], references: [id])

  @@index([lotId])  // lot detail page: fetch payments for a lot
  @@map("lot_payments")
}

enum Brand {
  iPhone
  GooglePixel @map("Google Pixel")
}

enum PtaStatus {
  JV
  PTA
  NonPTA  @map("Non-PTA")
  Patched
  CPID
}

enum Storage {
  GB64  @map("64GB")
  GB128 @map("128GB")
  GB256 @map("256GB")
  GB512 @map("512GB")
  TB1   @map("1TB")
}

enum Condition {
  New
  LikeNew     @map("Like New")
  Good
  Fair
  Poor
  Refurbished
}

enum PhoneStatus {
  available
  sold
  defective
  returned
}

model Phone {
  id            String      @id @default(uuid())
  lotId         String      @map("lot_id")
  brand         Brand
  model         String
  storage       Storage
  color         String
  imei          String      @unique
  condition     Condition
  batteryHealth Int?        @map("battery_health")
  costPrice     Decimal     @map("cost_price") @db.Decimal(12, 2)
  ptaStatus     PtaStatus?  @map("pta_status")
  sellerCnic    String?     @map("seller_cnic")
  sellerName    String?     @map("seller_name")
  status        PhoneStatus @default(available)
  notes         String?
  addedBy       String      @map("added_by")
  createdAt     DateTime    @default(now()) @map("created_at")

  lot   PurchaseLot @relation(fields: [lotId], references: [id])
  adder User        @relation(fields: [addedBy], references: [id])
  sale  Sale?

  @@index([status])           // inventory filter by status + dashboard phone count
  @@index([lotId, status])    // lots list: groupBy lotId+status to count available/sold
  @@index([brand])            // inventory filter by brand
  @@index([createdAt])        // dashboard activity feed: recent phones added
  @@map("phones")
}

model ShopBuyer {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  sales Sale[]

  @@map("shop_buyers")
}

enum SaleType {
  customer
  shop
}

model Sale {
  id             String   @id @default(uuid())
  phoneId        String   @unique @map("phone_id")
  saleType       SaleType @map("sale_type")
  shopBuyerId    String?  @map("shop_buyer_id")
  customerName   String?  @map("customer_name")
  sellingPrice   Decimal  @map("selling_price") @db.Decimal(12, 2)
  amountReceived Decimal  @default(0) @map("amount_received") @db.Decimal(12, 2)
  soldAt         DateTime @default(now()) @map("sold_at")
  notes          String?
  soldBy         String   @map("sold_by")

  phone     Phone      @relation(fields: [phoneId], references: [id])
  shopBuyer ShopBuyer? @relation(fields: [shopBuyerId], references: [id])
  seller    User       @relation(fields: [soldBy], references: [id])
  payments  SalePayment[]

  @@index([soldAt])        // dashboard counts, profit queries, reports date filtering
  @@index([saleType])      // reports: filter shop-only sales
  @@index([shopBuyerId])   // shop detail page: fetch all sales for a shop
  @@map("sales")
}

model SalePayment {
  id         String   @id @default(uuid())
  saleId     String   @map("sale_id")
  amount     Decimal  @db.Decimal(12, 2)
  receivedAt DateTime @default(now()) @map("received_at")
  notes      String?
  recordedBy String   @map("recorded_by")

  sale     Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  recorder User @relation(fields: [recordedBy], references: [id])

  @@index([saleId])      // sale detail: fetch payments for a sale
  @@index([receivedAt])  // dashboard activity feed: recent payments
  @@map("sale_payments")
}

enum ExpenseCategory {
  Rent
  Electricity
  Internet
  Food
  Salary
  Transport
  Other
}

model Expense {
  id          String          @id @default(uuid())
  amount      Decimal         @db.Decimal(12, 2)
  category    ExpenseCategory
  description String
  expenseDate DateTime        @map("expense_date")
  notes       String?
  recordedBy  String          @map("recorded_by")
  createdAt   DateTime        @default(now()) @map("created_at")

  recorder User @relation(fields: [recordedBy], references: [id])

  @@index([expenseDate])
  @@map("expenses")
}

model SupplierPayment {
  id         String   @id @default(uuid())
  supplierId String   @map("supplier_id")
  amount     Decimal  @db.Decimal(12, 2)
  paidAt     DateTime @default(now()) @map("paid_at")
  notes      String?
  recordedBy String   @map("recorded_by")

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  recorder User     @relation(fields: [recordedBy], references: [id])

  @@index([supplierId])  // supplier detail page: fetch all payments for a supplier
  @@map("supplier_payments")
}
